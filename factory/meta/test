test_script_syntax() {
  echo ":: Testing script syntax" >&2
  local scripts=(resolve gate complete run intake cancel score report triage track prereq validate sanitize-spec validate-behavior db merge-resolve install)

  for s in "${scripts[@]}"; do
    local full="$FACTORY_DIR/bin/$s"
    [[ -f "$full" ]] || continue
    if bash -n "$full" 2>/dev/null; then
      PASS=$((PASS + 1))
    else
      echo "  FAIL: bin/$s has syntax errors" >&2
      FAIL=$((FAIL + 1))
    fi
  done

  local meta_scripts=(meta/test meta/contribute)
  for s in "${meta_scripts[@]}"; do
    local full="$FACTORY_DIR/$s"
    [[ -f "$full" ]] || continue
    if bash -n "$full" 2>/dev/null; then
      PASS=$((PASS + 1))
    else
      echo "  FAIL: $s has syntax errors" >&2
      FAIL=$((FAIL + 1))
    fi
  done
  echo "  Checked $((${#scripts[@]} + ${#meta_scripts[@]})) scripts" >&2
}

