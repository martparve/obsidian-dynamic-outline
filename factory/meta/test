  #     factory/             <-- FACTORY_DIR (engine lives here)
  #       bin/install
  #       .factory-manifest
  #       ...
  local repo
  repo=$(mktemp -d)

  # Copy install-templates to repo root
  cp -R "$src_templates" "$repo/install-templates"

  # Create a factory/ subdirectory with engine files
  mkdir -p "$repo/factory/bin" "$repo/factory/meta"
  cp "$FACTORY_DIR/.factory-manifest" "$repo/factory/"
  cp "$FACTORY_DIR/bin/install" "$repo/factory/bin/install"
  chmod +x "$repo/factory/bin/install"
  # Symlink for backward compat
  ln -s "bin/install" "$repo/factory/install"

  # Verify install-templates is NOT inside factory/
  assert_eq "self-hosted: no templates in factory/" "false" \
    "$([[ -d "$repo/factory/install-templates" ]] && echo true || echo false)"

  # Create a target project to install into
  local target
  target=$(mktemp -d)
  git -C "$target" init -q 2>/dev/null

  # Fresh install from the self-hosted factory
  local output exit_code
  output=$("$repo/factory/bin/install" "$target" --language generic 2>&1) && exit_code=0 || exit_code=$?
  assert_eq "self-hosted: fresh install exits 0" "0" "$exit_code"
  assert_eq "self-hosted: factory.json created" "true" \
    "$([[ -f "$target/factory/factory.json" ]] && echo true || echo false)"

  # Now test --update from the self-hosted factory
  output=$("$repo/factory/bin/install" "$target" --update 2>&1) && exit_code=0 || exit_code=$?
  assert_eq "self-hosted: update exits 0" "0" "$exit_code"
  assert_contains "self-hosted: update message" "Updating engine" "$output"

  rm -rf "$repo" "$target"
}

