# Test: install --update works from self-hosted factory (templates at parent level)
test_install_self_hosted() {
  echo ":: Testing install --update from self-hosted factory (FM-073)" >&2

  local src_templates="$FACTORY_DIR/install-templates"
  [[ -d "$src_templates" ]] || src_templates="$FACTORY_DIR/../install-templates"
  if [[ ! -d "$src_templates" ]]; then
    echo "  SKIP: install-templates/ not found (target project)" >&2
    return 0
  fi

  # Build a self-hosted factory repo:
  #   repo_root/
