test_install() {
  echo ":: Testing install script" >&2
  if [[ "$IS_SOURCE_REPO" != "true" ]]; then
    echo "  SKIP: install script not present (target project)" >&2
    return 0
  fi

  local target
  target=$(mktemp -d)
  git -C "$target" init -q 2>/dev/null

  local output
  output=$("$INSTALL_SCRIPT" "$target" --language swift 2>&1)
  assert_contains "install runs" "Installing factory" "$output"

  assert_eq "factory/ dir created" "true" "$([[ -d "$target/factory" ]] && echo true || echo false)"

  assert_eq "bin/ dir created" "true" "$([[ -d "$target/factory/bin" ]] && echo true || echo false)"
  assert_eq "bin/resolve copied" "true" "$([[ -x "$target/factory/bin/resolve" ]] && echo true || echo false)"
  assert_eq "bin/gate copied" "true" "$([[ -x "$target/factory/bin/gate" ]] && echo true || echo false)"
  assert_eq "bin/complete copied" "true" "$([[ -x "$target/factory/bin/complete" ]] && echo true || echo false)"
  assert_eq "resolve symlink" "true" "$([[ -L "$target/factory/resolve" ]] && echo true || echo false)"
  assert_eq "gate symlink" "true" "$([[ -L "$target/factory/gate" ]] && echo true || echo false)"
  assert_eq "complete symlink" "true" "$([[ -L "$target/factory/complete" ]] && echo true || echo false)"
  assert_eq "resolve via symlink" "true" "$([[ -x "$target/factory/resolve" ]] && echo true || echo false)"

  assert_eq "factory.json created" "true" "$([[ -f "$target/factory/factory.json" ]] && echo true || echo false)"
  assert_eq "agents/ created" "true" "$([[ -d "$target/factory/agents" ]] && echo true || echo false)"
  assert_eq "quality/ created" "true" "$([[ -d "$target/factory/quality" ]] && echo true || echo false)"

  local swift_ext
  swift_ext=$(python3 -c "import json; d=json.load(open('$target/factory/factory.json')); print(d['project']['file_extensions'][0])" 2>/dev/null || true)
  assert_eq "swift factory.json has .swift" ".swift" "$swift_ext"

  assert_eq "backlog/ scaffolded" "true" "$([[ -d "$target/factory/backlog" ]] && echo true || echo false)"
  assert_eq "context/ scaffolded" "true" "$([[ -d "$target/factory/context" ]] && echo true || echo false)"
  assert_eq "tracking/ scaffolded" "true" "$([[ -d "$target/factory/tracking" ]] && echo true || echo false)"

  local tiers_in_json
  tiers_in_json=$(python3 -c "import json; d=json.load(open('$target/factory/factory.json')); print('true' if d.get('gate',{}).get('tiers') else 'false')" 2>/dev/null || echo "false")
  assert_eq "tiers in factory.json" "true" "$tiers_in_json"
  assert_eq "CLAUDE.md created" "true" "$([[ -f "$target/CLAUDE.md" ]] && echo true || echo false)"
  assert_contains "CLAUDE.md has factory section" "Factory" "$(cat "$target/CLAUDE.md")"

  assert_eq ".upstream-sha exists" "true" "$([[ -f "$target/factory/.upstream-sha" ]] && echo true || echo false)"
  assert_eq ".gitignore exists" "true" "$([[ -f "$target/factory/.gitignore" ]] && echo true || echo false)"

  # Re-install should be refused
  local output2
  output2=$("$INSTALL_SCRIPT" "$target" --language swift 2>&1 || true)
  assert_contains "re-install refused" "already exists" "$output2"

  # Update should work and not touch factory.json
  echo '{"modified":true}' > "$target/factory/factory.json"
  local output3
  output3=$("$INSTALL_SCRIPT" "$target" --update 2>&1)
  assert_contains "update runs" "Updating engine" "$output3"
  local still_modified
  still_modified=$(grep -c 'modified' "$target/factory/factory.json" || true)
  assert_eq "factory.json not overwritten by update" "1" "$still_modified"

  rm -rf "$target"
}

test_get_config() {
  echo ":: Testing get_config" >&2

  local tmp
  tmp=$(mktemp -d)
  cat > "$tmp/factory.json" <<'JSON'
{
  "schema_version": 1,
  "project": { "name": "test-app", "file_extensions": [".py", ".pyi"] },
  "pipeline": { "stages": ["spec", "test", "impl"], "stage_agents": { "spec": "spec-writer" } },
  "imports": { "pattern": "" },
  "gate": { "layer2_checks": ["secrets"] }
}
JSON

  _get_config() {
    local key="$1" default="${2:-}"
    local config="$tmp/factory.json"
    [[ -f "$config" ]] || { echo "$default"; return; }
    python3 -c "
import json,sys
d=json.load(open('$config'))
for k in '$key'.split('.'):
  if isinstance(d,dict): d=d.get(k,'')
  else: d=''
if isinstance(d,list): print('\n'.join(str(v) for v in d))
elif isinstance(d,dict): print(json.dumps(d))
else: print(d if d!='' else '$default')
" 2>/dev/null || echo "$default"
  }

  local val
  val=$(_get_config "project.name")
  assert_eq "get_config scalar" "test-app" "$val"

  val=$(_get_config "project.file_extensions")
  local line_count
  line_count=$(echo "$val" | wc -l | tr -d ' ')
  assert_eq "get_config list has 2 items" "2" "$line_count"
  assert_contains "get_config list has .py" ".py" "$val"

  val=$(_get_config "pipeline.stage_agents.spec")
  assert_eq "get_config nested key" "spec-writer" "$val"

  val=$(_get_config "nonexistent.key" "fallback")
  assert_eq "get_config missing key uses default" "fallback" "$val"

  val=$(_get_config "gate.layer2_checks")
  assert_eq "get_config single-item list" "secrets" "$val"

  rm -f "$tmp/factory.json"
  val=$(_get_config "project.name" "default-val")
  assert_eq "get_config missing file uses default" "default-val" "$val"

  rm -rf "$tmp"
}

test_extract_imports() {
  echo ":: Testing extract_imports" >&2

  local tmp
  tmp=$(mktemp -d)

  cat > "$tmp/swift_file.swift" <<'SRC'
import Foundation
import SwiftUI
import MapKit

struct MyView: View { }
SRC

  cat > "$tmp/python_file.py" <<'SRC'
import os
from pathlib import Path
import json
x = 42
SRC

  _extract_imports() {
    local file="$1" pattern="$2"
    [[ -n "$pattern" ]] || return 0
    python3 -c "
import re
pattern = r'$pattern'
with open('$file') as f:
  for line in f:
    m = re.match(pattern, line.strip())
    if m and m.group(1):
      print(m.group(1))
" 2>/dev/null || true
  }

  local result
  result=$(_extract_imports "$tmp/swift_file.swift" '^import\s+(\S+)')
  local count
  count=$(echo "$result" | wc -l | tr -d ' ')
  assert_eq "swift import count" "3" "$count"
  assert_contains "swift imports Foundation" "Foundation" "$result"
  assert_contains "swift imports SwiftUI" "SwiftUI" "$result"

  result=$(_extract_imports "$tmp/python_file.py" '^(?:import|from)\s+(\S+)')
  count=$(echo "$result" | wc -l | tr -d ' ')
  assert_eq "python import count" "3" "$count"
  assert_contains "python imports os" "os" "$result"
  assert_contains "python imports pathlib" "pathlib" "$result"

  result=$(_extract_imports "$tmp/swift_file.swift" '')
  assert_eq "empty pattern returns nothing" "" "$result"

  cat > "$tmp/no_imports.txt" <<'SRC'
hello world
no imports here
SRC
  result=$(_extract_imports "$tmp/no_imports.txt" '^import\s+(\S+)')
  assert_eq "no matching lines returns nothing" "" "$result"

  rm -rf "$tmp"
}

test_layer2_dispatch() {
  echo ":: Testing layer2 dispatch" >&2

  local tmp
  tmp=$(mktemp -d)
  git -C "$tmp" init -q 2>/dev/null
  echo "test" > "$tmp/file.txt"
  _test_commit "$tmp" "init"

  local saved_factory_dir="$FACTORY_DIR"

  local config_dir
  config_dir=$(mktemp -d)
  cat > "$config_dir/factory.json" <<'JSON'
{
  "schema_version": 1,
  "project": { "file_extensions": [".txt"] },
  "gate": { "layer2_checks": ["secrets"] }
}
JSON

  # Test: gate script sources get_config from FACTORY_DIR, so we test via the script
  # Verify unknown check name doesn't crash
  cat > "$config_dir/factory2.json" <<'JSON'
{
  "schema_version": 1,
  "project": { "file_extensions": [".txt"] },
  "gate": { "layer2_checks": ["nonexistent_check", "secrets"] }
}
JSON

  local output
  # Call gate's get_config inline to test dispatch logic
  output=$(
    FACTORY_DIR="$config_dir"
    get_config() {
      local key="$1" default="${2:-}"
      local config="$FACTORY_DIR/factory2.json"
      [[ -f "$config" ]] || { echo "$default"; return; }
      python3 -c "
import json,sys
d=json.load(open('$config'))
for k in '$key'.split('.'):
  if isinstance(d,dict): d=d.get(k,'')
  else: d=''
if isinstance(d,list): print('\n'.join(str(v) for v in d))
elif isinstance(d,dict): print(json.dumps(d))
else: print(d if d!='' else '$default')
" 2>/dev/null || echo "$default"
    }
    layer2_secrets() { return 0; }
    run_layer2() {
      local item_id="$1" worktree="$2"
      local failed=false
      local checks
      checks=$(get_config "gate.layer2_checks")
      [[ -n "$checks" ]] || { echo "PASS"; return; }
      while IFS= read -r check_name; do
        [[ -n "$check_name" ]] || continue
        local func_name="layer2_${check_name}"
        if declare -f "$func_name" > /dev/null 2>&1; then
          if ! "$func_name" "$item_id" "$worktree"; then
            failed=true
          fi
        else
          echo "WARN: unknown check '$check_name'" >&2
        fi
      done <<< "$checks"
      [[ "$failed" == "false" ]] && echo "PASS" || echo "FAIL"
    }
    run_layer2 "TEST" "$tmp" 2>&1
  )
  assert_contains "unknown check warns" "unknown check" "$output"
  assert_contains "dispatch still passes" "PASS" "$output"

  # Test: empty checks list
  cat > "$config_dir/factory3.json" <<'JSON'
{
  "schema_version": 1,
  "gate": { "layer2_checks": [] }
}
JSON
  output=$(
    FACTORY_DIR="$config_dir"
    get_config() {
      local key="$1" default="${2:-}"
      local config="$FACTORY_DIR/factory3.json"
      [[ -f "$config" ]] || { echo "$default"; return; }
      python3 -c "
import json,sys
d=json.load(open('$config'))
for k in '$key'.split('.'):
  if isinstance(d,dict): d=d.get(k,'')
  else: d=''
if isinstance(d,list): print('\n'.join(str(v) for v in d))
elif isinstance(d,dict): print(json.dumps(d))
else: print(d if d!='' else '$default')
" 2>/dev/null || echo "$default"
    }
    run_layer2() {
      local checks
      checks=$(get_config "gate.layer2_checks")
      [[ -n "$checks" ]] || { echo "PASS"; return; }
      echo "FAIL"
    }
    run_layer2
  )
  assert_eq "empty checks returns PASS" "PASS" "$output"

  rm -rf "$tmp" "$config_dir"
}

