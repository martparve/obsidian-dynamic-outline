test_gate_checks() {
  echo ":: Testing gate_checks telemetry (FM-029)" >&2
  local db_path="$FACTORY_DIR/.telemetry.db"
  local had_db=false
  [[ -f "$db_path" ]] && had_db=true

  "$FACTORY_DIR/db" init 2>/dev/null

  # verify gate_checks table exists
  local tables
  tables=$(sqlite3 "$db_path" ".tables" 2>/dev/null)
  assert_contains "gate_checks table exists" "gate_checks" "$tables"

  # verify schema columns
  local schema
  schema=$(sqlite3 "$db_path" "PRAGMA table_info(gate_checks);" 2>/dev/null)
  assert_contains "gate_checks has run_id column" "run_id" "$schema"
  assert_contains "gate_checks has layer column" "layer" "$schema"
  assert_contains "gate_checks has check_name column" "check_name" "$schema"
  assert_contains "gate_checks has outcome column" "outcome" "$schema"
  assert_contains "gate_checks has detail column" "detail" "$schema"

  # insert a run to get a valid run_id
  local run_id
  run_id=$("$FACTORY_DIR/db" insert-run \
    "TEST-CHK" "builder" "impl" 1 "medium" "" "pass" \
    "2026-01-01T00:00:00" "" "" "" 2>/dev/null)
  assert_eq "insert-run for checks test" "true" "$([[ -n "$run_id" ]] && echo true || echo false)"

  # insert-check: pass outcome
  "$FACTORY_DIR/db" insert-check "$run_id" 1 "scope_check" "pass" 2>/dev/null
  local pass_count
  pass_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM gate_checks WHERE run_id=$run_id AND check_name='scope_check' AND outcome='pass';" 2>/dev/null)
  assert_eq "insert-check pass" "1" "$pass_count"

  # insert-check: fail outcome
  "$FACTORY_DIR/db" insert-check "$run_id" 1 "build" "fail" 2>/dev/null
  local fail_count
  fail_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM gate_checks WHERE run_id=$run_id AND check_name='build' AND outcome='fail';" 2>/dev/null)
  assert_eq "insert-check fail" "1" "$fail_count"

  # insert-check: skip outcome with detail
  "$FACTORY_DIR/db" insert-check "$run_id" 2 "mainactor" "skip" "unknown check function" 2>/dev/null
  local skip_detail
  skip_detail=$(sqlite3 "$db_path" "SELECT detail FROM gate_checks WHERE run_id=$run_id AND check_name='mainactor' AND outcome='skip';" 2>/dev/null)
  assert_eq "insert-check skip with detail" "unknown check function" "$skip_detail"

  # insert-check: warn outcome
  "$FACTORY_DIR/db" insert-check "$run_id" 3 "evaluator" "warn" "human review required" 2>/dev/null
  local warn_count
  warn_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM gate_checks WHERE run_id=$run_id AND check_name='evaluator' AND outcome='warn';" 2>/dev/null)
  assert_eq "insert-check warn" "1" "$warn_count"

  # insert-check: null detail when omitted
  "$FACTORY_DIR/db" insert-check "$run_id" 1 "lint" "pass" 2>/dev/null
  local null_detail
  null_detail=$(sqlite3 "$db_path" "SELECT COALESCE(detail, 'NULL') FROM gate_checks WHERE run_id=$run_id AND check_name='lint';" 2>/dev/null)
  assert_eq "insert-check null detail" "NULL" "$null_detail"

  # layer constraint: only 1, 2, 3
  local bad_layer_result
  bad_layer_result=$("$FACTORY_DIR/db" insert-check "$run_id" 4 "bad" "pass" 2>&1 || true)
  local bad_layer_count
  bad_layer_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM gate_checks WHERE run_id=$run_id AND check_name='bad';" 2>/dev/null)
  assert_eq "insert-check rejects layer 4" "0" "$bad_layer_count"

  # outcome constraint: only pass, fail, skip, warn
  local bad_outcome_result
  bad_outcome_result=$("$FACTORY_DIR/db" insert-check "$run_id" 1 "bad2" "crash" 2>&1 || true)
  local bad_outcome_count
  bad_outcome_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM gate_checks WHERE run_id=$run_id AND check_name='bad2';" 2>/dev/null)
  assert_eq "insert-check rejects invalid outcome" "0" "$bad_outcome_count"

  # verify all valid checks were recorded
  local total
  total=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM gate_checks WHERE run_id=$run_id;" 2>/dev/null)
  assert_eq "total checks recorded" "5" "$total"

  # verify layer filter works
  local l1_count
  l1_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM gate_checks WHERE run_id=$run_id AND layer=1;" 2>/dev/null)
  assert_eq "layer 1 checks count" "3" "$l1_count"

  local l2_count
  l2_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM gate_checks WHERE run_id=$run_id AND layer=2;" 2>/dev/null)
  assert_eq "layer 2 checks count" "1" "$l2_count"

  local l3_count
  l3_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM gate_checks WHERE run_id=$run_id AND layer=3;" 2>/dev/null)
  assert_eq "layer 3 checks count" "1" "$l3_count"

  # report checks subcommand
  local report_output
  report_output=$("$FACTORY_DIR/report" checks 2>/dev/null || true)
  assert_contains "report checks shows check_name" "scope_check" "$report_output"
  assert_contains "report checks shows layer" "1" "$report_output"

  # report all includes checks section
  local report_all
  report_all=$("$FACTORY_DIR/report" all 2>/dev/null || true)
  assert_contains "report all includes checks" "Per-Check" "$report_all"

  # cleanup
  sqlite3 "$db_path" "DELETE FROM gate_checks WHERE run_id=$run_id;" 2>/dev/null
  sqlite3 "$db_path" "DELETE FROM gate_runs WHERE item_id='TEST-CHK';" 2>/dev/null
  if [[ "$had_db" == "false" ]]; then
    rm -f "$db_path"
  fi
}

