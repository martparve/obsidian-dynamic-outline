#!/usr/bin/env bash
set -euo pipefail

META_DIR="$(cd "$(dirname "$0")" && pwd)"
# Detect if running from factory/meta/ or root meta/
if [[ -d "$META_DIR/../factory" ]]; then
  FACTORY_DIR="$(cd "$META_DIR/../factory" && pwd)"
  PROJECT_ROOT="$(cd "$META_DIR/.." && pwd)"
else
  FACTORY_DIR="$(cd "$META_DIR/.." && pwd)"
  PROJECT_ROOT="$(cd "$FACTORY_DIR/.." && pwd)"
fi
FACTORY_DIR_ORIG="$FACTORY_DIR"
INSTALL_SCRIPT="$PROJECT_ROOT/install"
[[ -f "$INSTALL_SCRIPT" ]] || INSTALL_SCRIPT="$PROJECT_ROOT/bin/install"
IS_SOURCE_REPO=$([[ -f "$INSTALL_SCRIPT" ]] && echo true || echo false)
TEST_DIR=""
PASS=0
FAIL=0

# --- functions ---

die() { echo "ERROR: $*" >&2; exit 1; }

setup() {
  TEST_DIR=$(mktemp -d)
  mkdir -p "$TEST_DIR/backlog" "$TEST_DIR/.runs" "$TEST_DIR/agents" \
    "$TEST_DIR/context" "$TEST_DIR/quality" "$TEST_DIR/quality/rubrics"

  cat > "$TEST_DIR/backlog/TEST-001.md" <<'ITEM'
---
id: TEST-001
title: Test item
status: open
priority: 1
files:
  - test-file.swift
tags:
  - concurrency
depends-on: []
---

Test item for factory validation.
ITEM

  cat > "$TEST_DIR/backlog/TEST-002.md" <<'ITEM'
---
id: TEST-002
title: Blocked item
status: open
priority: 2
files:
  - other-file.swift
depends-on:
  - TEST-001
---

Depends on TEST-001.
ITEM

  cat > "$TEST_DIR/backlog/TEST-003.md" <<'ITEM'
---
id: TEST-003
title: Fixed item
status: fixed
priority: 1
files:
  - done-file.swift
---

Already done.
ITEM
}

teardown() {
  [[ -n "$TEST_DIR" ]] && rm -rf "$TEST_DIR"
}

assert_eq() {
  local desc="$1" expected="$2" actual="$3"
  if [[ "$expected" == "$actual" ]]; then
    echo "  PASS: $desc" >&2
    PASS=$((PASS + 1))
  else
    echo "  FAIL: $desc (expected '$expected', got '$actual')" >&2
    FAIL=$((FAIL + 1))
  fi
}

assert_contains() {
  local desc="$1" needle="$2" haystack="$3"
  if echo "$haystack" | grep -q "$needle" 2>/dev/null; then
    echo "  PASS: $desc" >&2
    PASS=$((PASS + 1))
  else
    echo "  FAIL: $desc (expected to contain '$needle')" >&2
    FAIL=$((FAIL + 1))
  fi
}

assert_exit() {
  local desc="$1" expected="$2"
  shift 2
  "$@" >/dev/null 2>&1
  local actual=$?
  assert_eq "$desc" "$expected" "$actual"
}

# Generate a one-time commit token for a test project so the pre-commit hook allows the commit
_gen_token() {
  local project="$1"
  [[ -f "$project/factory/factory.json" ]] || return 0
  mkdir -p "$project/factory/.runs"
  python3 -c "import secrets; print(secrets.token_hex(16))" > "$project/factory/.runs/.commit-token"
}

# Commit all changes in a test project, safely excluding runtime artifacts
_test_commit() {
  local project="$1" msg="$2"
  _gen_token "$project"
  git -C "$project" add -A 2>/dev/null
  git -C "$project" reset HEAD -- factory/.runs/ 2>/dev/null || true
  git -C "$project" commit -q -m "$msg" 2>/dev/null
}

