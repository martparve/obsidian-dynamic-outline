  assert_eq "self-hosted sync: factory/meta/test matches meta/test" "true" "$meta_match"

  # Verify the sync message was printed
  assert_contains "self-hosted sync: message printed" "Self-hosted sync" "$output"

  # ---- Test non-self-hosted is unaffected ----
  local project2
  project2=$(mktemp -d)
  git -C "$project2" init -q -b main 2>/dev/null
  echo "init" > "$project2/README.md"
  _test_commit "$project2" "init"

  # Non-self-hosted: only factory/bin/ exists, no root bin/
  mkdir -p "$project2/factory/bin" "$project2/factory/backlog" "$project2/factory/.runs"
  cp "$FACTORY_DIR/bin/complete" "$project2/factory/bin/complete"
  cp "$FACTORY_DIR/bin/db" "$project2/factory/bin/db"
  chmod +x "$project2/factory/bin/complete" "$project2/factory/bin/db"
  ln -sf "bin/complete" "$project2/factory/complete"
  ln -sf "bin/db" "$project2/factory/db"

  cat > "$project2/factory/backlog/SYNC-002.md" <<'ITEM'
---
id: SYNC-002
title: Non-self-hosted test
status: open
priority: 1
files:
  - README.md
depends-on: []
---

Test that non-self-hosted is unaffected.
ITEM

  _test_commit "$project2" "add factory"

  git -C "$project2" checkout -b "fix/SYNC-002" 2>/dev/null
  echo "changed" > "$project2/README.md"
  _test_commit "$project2" "impl(SYNC-002): change"
  git -C "$project2" checkout main 2>/dev/null

  local wt2="/tmp/SYNC-002"
  rm -rf "$wt2"
  git -C "$project2" worktree add "$wt2" "fix/SYNC-002" 2>/dev/null

  cat > "$project2/factory/.runs/SYNC-002.json" <<JSON
{
  "item_id": "SYNC-002",
  "worktree": "$wt2",
  "gate_result": "pass"
}
JSON

  printf 'SYNC-002\t%s\t%s\n' "$(date '+%Y-%m-%dT%H:%M:%S')" "$$" > "$project2/factory/.in-progress"

  local output2 exit_code2
  output2=$("$project2/factory/complete" SYNC-002 2>&1) && exit_code2=0 || exit_code2=$?

  assert_eq "non-self-hosted: complete exits 0" "0" "$exit_code2"

  # Verify no sync message
  local has_sync_msg="false"
  echo "$output2" | grep -q "Self-hosted sync" && has_sync_msg="true"
  assert_eq "non-self-hosted: no sync message" "false" "$has_sync_msg"

  # Clean up
  git -C "$project" worktree remove --force "$wt" 2>/dev/null || true
  git -C "$project" worktree prune 2>/dev/null || true
  git -C "$project2" worktree remove --force "$wt2" 2>/dev/null || true
  git -C "$project2" worktree prune 2>/dev/null || true
  rm -rf "$project" "$project2"
}

# Test auto-pair files and backlog exclusion from atomicity cap (FM-077)
test_auto_pair_files() {
  echo ":: Testing auto-pair files and backlog exclusion (FM-077)" >&2
  if [[ "$IS_SOURCE_REPO" != "true" ]]; then
    echo "  SKIP: install not present (target project)" >&2
    return 0
  fi

  # Clean up stale worktrees from previous interrupted runs
  for stale_dir in /tmp/PAIR-001 /tmp/PAIR-002 /tmp/GATE-001; do
    [[ -d "$stale_dir" ]] && rm -rf "$stale_dir"
  done

  local project
  project=$(mktemp -d)
  git -C "$project" init -q -b main 2>/dev/null
  echo "# test" > "$project/README.md"
  mkdir -p "$project/src"
  echo "print('hello')" > "$project/src/main.py"
  _test_commit "$project" "init"

  "$INSTALL_SCRIPT" "$project" --language python >/dev/null 2>&1
  _test_commit "$project" "add factory"

  # Override test/lint commands so they pass
  python3 -c "
import json
f = '$project/factory/factory.json'
with open(f) as fh:
    d = json.load(fh)
d['commands']['test'] = ''
d['commands']['lint'] = ''
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
"

  # ---- Test 1: bin/test in files list auto-pairs meta/test ----
  cat > "$project/factory/backlog/PAIR-001.md" <<'ITEM'
---
id: PAIR-001
title: Auto-pair test
status: open
priority: 1
files:
  - bin/test
depends-on: []
---

Test that bin/test auto-pairs with meta/test.
ITEM

  _test_commit "$project" "add PAIR-001"

  local output exit_code
  output=$("$project/factory/resolve" PAIR-001 2>&1) && exit_code=0 || exit_code=$?

  assert_eq "pair: resolve exits 0" "0" "$exit_code"
  assert_contains "pair: auto-paired message" "Auto-paired: meta/test" "$output"

  # Verify meta/test appears in the prompt scope
  assert_contains "pair: prompt has meta/test" "meta/test" "$output"

  # Verify the frontmatter was updated
  local files_after
  files_after=$(sed -n '/^---$/,/^---$/p' "$project/factory/backlog/PAIR-001.md" | sed -n '/^files:$/,/^[^ ]/p' | grep '^ *- ' | sed 's/^ *- *//')
  assert_contains "pair: frontmatter has meta/test" "meta/test" "$files_after"

  git -C "$project" worktree remove --force "/tmp/PAIR-001" 2>/dev/null || true
  git -C "$project" branch -D "fix/PAIR-001" 2>/dev/null || true
  rm -f "$project/factory/.in-progress"
  rm -rf "$project/factory/.runs"
  rm -rf "$project/factory/.resolve.lock"

  # ---- Test 2: backlog self-reference excluded from atomicity count ----
  # Set max_files_modified to 5 explicitly
  cat > "$project/factory/context/atomicity.json" <<'JSON'
{
  "implementation": {
    "max_files_modified": 5,
    "single_feature": true,
    "allowed_exceptions": []
  }
}
JSON

  # 5 real files + 1 backlog self-reference = 6 total, but should pass (backlog excluded)
  cat > "$project/factory/backlog/PAIR-002.md" <<'ITEM'
---
id: PAIR-002
title: Backlog exclusion test
status: open
priority: 1
files:
  - src/a.py
  - src/b.py
  - src/c.py
  - src/d.py
  - src/e.py
  - factory/backlog/PAIR-002.md
depends-on: []
---

Test that backlog self-reference is excluded from atomicity count.
ITEM

  _test_commit "$project" "add PAIR-002"

  output=$("$project/factory/resolve" PAIR-002 2>&1) && exit_code=0 || exit_code=$?
  assert_eq "backlog-excl: resolve exits 0 (5 code + 1 backlog)" "0" "$exit_code"

  git -C "$project" worktree remove --force "/tmp/PAIR-002" 2>/dev/null || true
  git -C "$project" branch -D "fix/PAIR-002" 2>/dev/null || true
  rm -f "$project/factory/.in-progress"
  rm -rf "$project/factory/.runs"
  rm -rf "$project/factory/.resolve.lock"

  # ---- Test 3: gate allows factory/bin/X when bin/X is declared (self-hosted) ----
  # Build a self-hosted project with both bin/ and factory/bin/
  local sh_project
  sh_project=$(mktemp -d)
  git -C "$sh_project" init -q -b main 2>/dev/null
  echo "init" > "$sh_project/README.md"
  mkdir -p "$sh_project/bin" "$sh_project/factory/bin" \
    "$sh_project/factory/backlog" "$sh_project/factory/.runs"

  # Copy gate script
  cp "$FACTORY_DIR/bin/gate" "$sh_project/factory/bin/gate"
  cp "$FACTORY_DIR/bin/db" "$sh_project/factory/bin/db"
  chmod +x "$sh_project/factory/bin/gate" "$sh_project/factory/bin/db"
  ln -sf "bin/gate" "$sh_project/factory/gate"
  ln -sf "bin/db" "$sh_project/factory/db"

  # Create a script in both locations
  echo '#!/usr/bin/env bash' > "$sh_project/bin/resolve"
  echo 'echo original' >> "$sh_project/bin/resolve"
  cp "$sh_project/bin/resolve" "$sh_project/factory/bin/resolve"

  cat > "$sh_project/factory/backlog/GATE-001.md" <<'ITEM'
---
id: GATE-001
title: Self-hosted gate test
status: open
priority: 1
files:
  - bin/resolve
depends-on: []
---

Test that gate allows factory/bin/resolve when bin/resolve is declared.
ITEM

  _test_commit "$sh_project" "init"

  # Create a fix branch that changes both bin/resolve and factory/bin/resolve
  git -C "$sh_project" checkout -b "fix/GATE-001" 2>/dev/null
  echo '#!/usr/bin/env bash' > "$sh_project/bin/resolve"
  echo 'echo changed' >> "$sh_project/bin/resolve"
  echo '#!/usr/bin/env bash' > "$sh_project/factory/bin/resolve"
  echo 'echo changed' >> "$sh_project/factory/bin/resolve"
  _test_commit "$sh_project" "impl(GATE-001): change resolve"

  git -C "$sh_project" checkout main 2>/dev/null

  local wt="/tmp/GATE-001"
  rm -rf "$wt"
  git -C "$sh_project" worktree add "$wt" "fix/GATE-001" 2>/dev/null

  cat > "$sh_project/factory/.runs/GATE-001.json" <<JSON
{
  "item_id": "GATE-001",
  "run_id": 0,
  "worktree": "$wt",
  "gate_weight": "light"
}
JSON

  # Run the gate's diff check via a helper
  local gate_helper="$sh_project/_gate_helper.sh"
  cat > "$gate_helper" <<HELPER
#!/usr/bin/env bash
set +euo pipefail
FACTORY_DIR="$sh_project/factory"
PROJECT_ROOT="$sh_project"
RUNS_DIR="$sh_project/factory/.runs"
DB_PATH="$sh_project/factory/.telemetry.db"
DEFAULT_BRANCH="main"
record_rejection() { :; }
get_run_field() { echo ""; }
$(sed -n '/^get_config()/,/^}/p' "$FACTORY_DIR/gate")
$(sed -n '/^layer1_diff_check()/,/^}/p' "$FACTORY_DIR/gate")
layer1_diff_check "GATE-001" "$wt"
HELPER

  local diff_result
  diff_result=$(bash "$gate_helper" 2>/dev/null)
  assert_eq "gate-selfhosted: diff check passes with factory/bin/X" "OK" "$diff_result"

  # Clean up
  git -C "$sh_project" worktree remove --force "$wt" 2>/dev/null || true
  git -C "$sh_project" worktree prune 2>/dev/null || true
  git -C "$sh_project" branch -D "fix/GATE-001" 2>/dev/null || true
  rm -rf "$sh_project" "$project"
}

# --- main ---

main() {
  local section="${1:-all}"

  echo ":: Factory test suite" >&2
  echo "" >&2

  setup
  trap teardown EXIT

  case "$section" in
    all)
      test_db
      test_gate_checks
      test_triage_frontmatter
      test_script_syntax
      test_script_permissions
      test_validate_behavior
      test_manifest
      test_factory_json
      test_install_templates
      test_install
      test_contribute
      test_get_config
      test_extract_imports
      test_layer2_dispatch
      test_copy_templates
      test_resolve_integration
      test_test_coverage
      test_test_fallback
      test_imports_fallback
      test_complete_merge_failure
      test_acceptance
      test_commit_tokens
      test_install_self_hosted
      test_violation_lockout
      test_self_hosted_sync
      test_auto_pair_files
      ;;
    db)               test_db ;;
    gate_checks)      test_gate_checks ;;
    parse)            test_triage_frontmatter ;;
    syntax)           test_script_syntax ;;
    perms)            test_script_permissions ;;
    behavior)         test_validate_behavior ;;
    manifest)         test_manifest ;;
    factory_json)     test_factory_json ;;
    install_templates) test_install_templates ;;
    install)          test_install ;;
    contribute)       test_contribute ;;
    get_config)       test_get_config ;;
    extract_imports)  test_extract_imports ;;
    layer2_dispatch)  test_layer2_dispatch ;;
    copy_templates)   test_copy_templates ;;
    resolve_integration) test_resolve_integration ;;
    test_coverage)    test_test_coverage ;;
    test_fallback)    test_test_fallback ;;
    imports_fallback)  test_imports_fallback ;;
    complete_merge_failure) test_complete_merge_failure ;;
    acceptance)       test_acceptance ;;
    commit_tokens)    test_commit_tokens ;;
    install_self_hosted) test_install_self_hosted ;;
    violation_lockout) test_violation_lockout ;;
    self_hosted_sync) test_self_hosted_sync ;;
    auto_pair_files)  test_auto_pair_files ;;
    *)
      die "Unknown section: $section. Valid: all, db, gate_checks, parse, syntax, perms, behavior, manifest, factory_json, install_templates, install, contribute, get_config, extract_imports, layer2_dispatch, copy_templates, resolve_integration, test_coverage, test_fallback, imports_fallback, complete_merge_failure, acceptance, commit_tokens, install_self_hosted, violation_lockout, self_hosted_sync, auto_pair_files"
      ;;
  esac

  echo "" >&2
  echo ":: Results: $PASS passed, $FAIL failed" >&2
  [[ "$FAIL" -eq 0 ]]
}

main "$@"
