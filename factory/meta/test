# Test violation lockout mechanism (FM-075)
test_violation_lockout() {
  echo ":: Testing violation lockout (FM-075)" >&2

  # Find hooks directory - may be at FACTORY_DIR/install-templates or FACTORY_DIR/../install-templates
  local hooks_dir="$FACTORY_DIR/install-templates/hooks"
  [[ -d "$hooks_dir" ]] || hooks_dir="$FACTORY_DIR/../install-templates/hooks"
  if [[ ! -d "$hooks_dir" ]]; then
    echo "  SKIP: install-templates/hooks/ not found (target project)" >&2
    return 0
  fi

  local project
  project=$(mktemp -d)
  git -C "$project" init -q -b main 2>/dev/null
  echo "init" > "$project/README.md"
  mkdir -p "$project/src"
  echo "print('hello')" > "$project/src/main.py"
  _test_commit "$project" "init"

  # Set up factory structure with hooks
  mkdir -p "$project/factory/.runs" "$project/factory/backlog"
  cp "$hooks_dir/post-bash-monitor.sh" "$project/_post_bash_monitor.sh"
  cp "$hooks_dir/enforce-worktree.sh" "$project/_enforce_worktree.sh"
  cp "$hooks_dir/enforce-factory-flow.sh" "$project/_enforce_factory_flow.sh"
  chmod +x "$project/_post_bash_monitor.sh" "$project/_enforce_worktree.sh" "$project/_enforce_factory_flow.sh"

  # Test 1: post-bash-monitor creates lockout file when source files modified on main
  echo "modified" > "$project/src/main.py"
  local output
  output=$(cd "$project" && echo '{}' | bash "$project/_post_bash_monitor.sh" 2>&1) || true
  assert_eq "lockout: file created on violation" "true" \
    "$([[ -f "$project/factory/.runs/.violation-lockout" ]] && echo true || echo false)"
  assert_contains "lockout: file lists modified source" "src/main.py" \
    "$(cat "$project/factory/.runs/.violation-lockout" 2>/dev/null)"

  # Test 2: post-bash-monitor clears lockout when violations reverted
  git -C "$project" checkout -- src/main.py 2>/dev/null
  output=$(cd "$project" && echo '{}' | bash "$project/_post_bash_monitor.sh" 2>&1) || true
  assert_eq "lockout: file removed after revert" "false" \
    "$([[ -f "$project/factory/.runs/.violation-lockout" ]] && echo true || echo false)"

  # Test 3: enforce-worktree blocks Edit/Write when lockout exists
  echo "src/main.py" > "$project/factory/.runs/.violation-lockout"
  local ew_input='{"tool_name":"Edit","tool_input":{"file_path":"/tmp/some/file.py","old_string":"x","new_string":"y"}}'
