  ew_output=$(cd "$project" && echo "$ew_input" | bash "$project/_enforce_worktree.sh" 2>&1) && ew_exit=0 || ew_exit=$?
  assert_eq "lockout: enforce-worktree blocks edit" "2" "$ew_exit"
  assert_contains "lockout: enforce-worktree message" "BLOCKED" "$ew_output"

  # Test 4: enforce-factory-flow allows git checkout during lockout
  local ef_input_checkout='{"tool_name":"Bash","tool_input":{"command":"git checkout -- src/main.py"}}'
  local ef_output ef_exit
  ef_output=$(cd "$project" && echo "$ef_input_checkout" | bash "$project/_enforce_factory_flow.sh" 2>&1) && ef_exit=0 || ef_exit=$?
  assert_eq "lockout: factory-flow allows git checkout" "0" "$ef_exit"

  # Also test git restore and git diff are allowed
  local ef_input_restore='{"tool_name":"Bash","tool_input":{"command":"git restore src/main.py"}}'
  ef_output=$(cd "$project" && echo "$ef_input_restore" | bash "$project/_enforce_factory_flow.sh" 2>&1) && ef_exit=0 || ef_exit=$?
  assert_eq "lockout: factory-flow allows git restore" "0" "$ef_exit"

  local ef_input_status='{"tool_name":"Bash","tool_input":{"command":"git status"}}'
  ef_output=$(cd "$project" && echo "$ef_input_status" | bash "$project/_enforce_factory_flow.sh" 2>&1) && ef_exit=0 || ef_exit=$?
  assert_eq "lockout: factory-flow allows git status" "0" "$ef_exit"

  # Test 5: enforce-factory-flow blocks non-revert commands during lockout
  local ef_input_build='{"tool_name":"Bash","tool_input":{"command":"python3 src/main.py"}}'
  ef_output=$(cd "$project" && echo "$ef_input_build" | bash "$project/_enforce_factory_flow.sh" 2>&1) && ef_exit=0 || ef_exit=$?
  assert_eq "lockout: factory-flow blocks non-revert cmd" "2" "$ef_exit"
